APP_URL=http://localhost
FRONTEND_URL=http://localhost
API_URL=http://localhost/api
SEED_DEMO_CONTENT=false

POSTGRES_DB=replypro
POSTGRES_USER=replypro
POSTGRES_PASSWORD=supersecretpassword
EVOLUTION_POSTGRES_DB=replypro_evolution_v211

# Optional: guna external PostgreSQL seperti Supabase untuk app DB.
# Kalau kosong, backend/worker akan fallback ke postgres container local.
DATABASE_URL=

REDIS_HOST=redis
REDIS_PORT=6379
BULLMQ_PREFIX=replypro

JWT_SECRET=replace_with_long_random_secret
JWT_EXPIRES_IN=7d
ENCRYPTION_KEY=replace_with_32_char_key_here

EVOLUTION_API_KEY=replace_with_evolution_key
# Optional: URL public untuk Evolution server (guna domain/IP VPS bila deploy).
EVOLUTION_SERVER_URL=

OPENAI_API_KEY=replace_with_openai_key
OPENAI_MODEL=gpt-4o-mini

WORKER_CONCURRENCY=20
CAMPAIGN_BATCH_SIZE=50
CAMPAIGN_MIN_DELAY_MS=5000
CAMPAIGN_MAX_DELAY_MS=25000
